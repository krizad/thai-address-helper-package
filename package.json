{
  "name": "@krizad/thai-location-kit",
  "version": "1.0.0",
  "description": "Lightweight Thai address lookup engine",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
